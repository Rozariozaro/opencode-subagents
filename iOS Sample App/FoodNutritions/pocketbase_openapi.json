  "paths": {
    "/api/collections/_superusers/auth-with-password": {
      "post": {
        "summary": "Authenticate as superuser",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "identity",
                  "password"
                ],
                "properties": {
                  "identity": {
                    "type": "string",
                    "example": "admin@rapheal.in"
                  },
                  "password": {
                    "type": "string",
                    "format": "password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Auth token + admin record",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "record": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
